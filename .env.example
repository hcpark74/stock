# ── KIS API ──────────────────────────────────────────────────────────
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=12345678-01
KIS_ACCOUNT_TYPE=01

# PAPER: 모의투자 / REAL: 실계좌
KIS_MODE=PAPER

# 모의투자
KIS_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_WS_URL=ws://ops.koreainvestment.com:31000

# 실계좌 (REAL 전환 시 아래 두 줄로 교체)
# KIS_BASE_URL=https://openapi.koreainvestment.com:9443
# KIS_WS_URL=ws://ops.koreainvestment.com:21000

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── 시스템 ───────────────────────────────────────────────────────────
NTP_SERVER=time.google.com,time.windows.com,kr.pool.ntp.org
LOG_DIR=data/logs
STATE_DIR=data/state
PARAMS_DIR=data/params
AUTH_DIR=data/auth
DB_DIR=data/db

# Safe end-to-end simulation. When enabled, the app skips KIS auth/API/orders
# and WebSocket, then runs F1->F4 with deterministic sample data.
DRY_RUN=0
DRY_RUN_TICKER=005930
DRY_RUN_PREV_CLOSE=10000
DRY_RUN_EXPECTED_PRICE=10300
DRY_RUN_ENTRY_QTY=10
DRY_RUN_STEP_DELAY=0.2
DRY_RUN_LOG_DIR=data/dry_run/logs
DRY_RUN_STATE_DIR=data/dry_run/state
DRY_RUN_DB_DIR=data/dry_run/db

# F1 expected quote enrichment concurrency. Keep this modest for KIS rate limits.
F1_EXPECTED_QUOTE_CONCURRENCY=8
